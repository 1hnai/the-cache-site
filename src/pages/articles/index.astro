---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Picks — The Cache"
  description="The best gear, tech, fashion, cars, and drinks — curated weekly by The Cache."
>
  <h1 style="font-size:1.75rem; font-weight:800; letter-spacing:-0.02em; margin-bottom:0.5rem; font-family:Georgia,serif;">The Picks</h1>
  <p style="color:var(--brand-muted); margin-bottom:3rem;">Gear, tech, style, cars, and drinks worth your attention.</p>

  <div style="text-align:center; padding:4rem 0; border:1px dashed var(--brand-border); border-radius:12px;">
    <p style="font-size:1.1rem; font-weight:600; margin-bottom:0.5rem;">First drop coming soon</p>
    <p style="color:var(--brand-muted); margin-bottom:1.5rem;">Subscribe to get notified when we launch.</p>
    <div style="display:flex; gap:0.5rem; max-width:380px; margin:0 auto;">
      <input type="email" placeholder="your@email.com" style="flex:1; padding:0.6rem 1rem; border-radius:8px; border:1px solid #292524; background:#1c1917; color:white; font-size:0.95rem;" />
      <button style="padding:0.6rem 1.25rem; border-radius:8px; font-weight:600; font-size:0.9rem; border:none; background:var(--brand-accent); color:white; cursor:pointer;">Notify me</button>
    </div>
  </div>
</BaseLayout>
