---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = await getCollection('articles', ({ data }) => data.status === 'live' || data.status === 'approved');
articles.sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime());

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout
  title="Picks — The Cache"
  description="Gear, tech, style, cars, and drinks worth your attention."
>
  <div class="page-header">
    <h1 class="page-title">The Picks</h1>
    <p class="page-sub">Gear, tech, style, cars, and drinks worth your attention.</p>
  </div>

  {articles.length > 0 ? (
    <div class="picks-list">
      {articles.map(article => (
        <a href={`/articles/${article.slug}`} class="pick-row">
          {article.data.image && (
            <div class="pick-thumb">
              <img src={article.data.image} alt={article.data.title} loading="lazy" />
            </div>
          )}
          <div class="pick-info">
            <div class="pick-meta">
              <span class="pick-cat">{article.data.category}</span>
              <span class="pick-date">{formatDate(article.data.publishedDate)}</span>
            </div>
            <h2 class="pick-title">{article.data.title}</h2>
            <p class="pick-desc">{article.data.description}</p>
            {article.data.price && <span class="pick-price">{article.data.price}</span>}
          </div>
          <div class="pick-arrow" aria-hidden="true">&#8594;</div>
        </a>
      ))}
    </div>
  ) : (
    <p class="empty">First picks coming soon.</p>
  )}
</BaseLayout>

<style>
  .page-header {
    padding: 2rem 0 2.5rem;
    border-bottom: 1px solid var(--brand-border);
    margin-bottom: 2rem;
  }

  .page-title {
    font-family: var(--font-serif);
    font-size: 1.85rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.4rem;
    color: var(--brand-text);
  }

  .page-sub {
    color: var(--brand-muted);
    font-size: 0.9375rem;
  }

  .picks-list {
    display: flex;
    flex-direction: column;
  }

  .pick-row {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--brand-border);
    text-decoration: none;
    color: inherit;
    transition: background 0.1s;
    align-items: flex-start;
    position: relative;
  }

  .pick-row:first-child {
    padding-top: 0;
  }

  .pick-row:hover .pick-title {
    color: var(--brand-accent);
  }

  .pick-thumb {
    width: 140px;
    height: 100px;
    flex-shrink: 0;
    border-radius: 5px;
    overflow: hidden;
    background: var(--brand-surface);
  }

  .pick-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pick-info {
    flex: 1;
    min-width: 0;
  }

  .pick-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.4rem;
  }

  .pick-cat {
    font-size: 0.675rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-accent);
  }

  .pick-date {
    font-size: 0.75rem;
    color: var(--brand-muted);
  }

  .pick-title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
    line-height: 1.3;
    color: var(--brand-text);
    transition: color 0.15s;
  }

  .pick-desc {
    font-size: 0.875rem;
    color: var(--brand-muted);
    line-height: 1.55;
    margin-bottom: 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .pick-price {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--brand-muted);
  }

  .pick-arrow {
    color: var(--brand-border-strong);
    font-size: 1.1rem;
    align-self: center;
    flex-shrink: 0;
    transition: color 0.15s, transform 0.15s;
  }

  .pick-row:hover .pick-arrow {
    color: var(--brand-accent);
    transform: translateX(3px);
  }

  .empty {
    color: var(--brand-muted);
    font-style: italic;
    padding: 2rem 0;
  }

  @media (max-width: 600px) {
    .pick-thumb {
      width: 90px;
      height: 68px;
    }
    .pick-arrow { display: none; }
    .pick-desc { display: none; }
  }
</style>
