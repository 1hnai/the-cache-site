---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = await getCollection('articles', ({ data }) => data.status === 'live');
articles.sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime());
---

<BaseLayout
  title="Picks — The Cache"
  description="Gear, tech, style, cars, and drinks worth your attention."
>
  <h1 class="page-title">The Picks</h1>
  <p class="page-sub">Gear, tech, style, cars, and drinks worth your attention.</p>

  {articles.length > 0 ? (
    <div class="picks-list">
      {articles.map(article => (
        <a href={`/articles/${article.slug}`} class="pick-row">
          {article.data.image && (
            <div class="pick-thumb">
              <img src={article.data.image} alt={article.data.title} loading="lazy" />
            </div>
          )}
          <div class="pick-info">
            <span class="pick-cat">{article.data.category}</span>
            <h2 class="pick-title">{article.data.title}</h2>
            <p class="pick-desc">{article.data.description}</p>
            {article.data.price && <span class="pick-price">{article.data.price}</span>}
          </div>
        </a>
      ))}
    </div>
  ) : (
    <p class="empty">First picks coming soon.</p>
  )}
</BaseLayout>

<style>
  .page-title {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 0.4rem;
    font-family: Georgia, serif;
  }

  .page-sub {
    color: var(--brand-muted);
    margin-bottom: 3rem;
  }

  .picks-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    border: 1px solid var(--brand-border);
    border-radius: 10px;
    overflow: hidden;
    background: var(--brand-border);
  }

  .pick-row {
    display: flex;
    gap: 1.25rem;
    background: white;
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.1s;
    align-items: flex-start;
  }

  .pick-row:hover {
    background: var(--brand-surface);
    text-decoration: none;
  }

  .pick-thumb {
    width: 100px;
    height: 70px;
    flex-shrink: 0;
    border-radius: 6px;
    overflow: hidden;
    background: var(--brand-surface);
  }

  .pick-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pick-info {
    flex: 1;
    min-width: 0;
  }

  .pick-cat {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--brand-accent);
    display: block;
    margin-bottom: 0.3rem;
  }

  .pick-title {
    font-size: 1rem;
    font-weight: 700;
    font-family: Georgia, serif;
    margin-bottom: 0.3rem;
    line-height: 1.3;
  }

  .pick-desc {
    font-size: 0.875rem;
    color: var(--brand-muted);
    margin: 0 0 0.4rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .pick-price {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--brand-muted);
  }

  .empty {
    color: var(--brand-muted);
    font-style: italic;
  }

  @media (max-width: 500px) {
    .pick-thumb { display: none; }
  }
</style>
