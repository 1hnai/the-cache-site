---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = await getCollection('articles');
articles.sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime());

const categoryColors: Record<string, string> = {
  gear: '#c2410c',
  tech: '#0369a1',
  drinks: '#7c3aed',
  style: '#4f7942',
  cars: '#b45309',
};
---

<BaseLayout
  title="Picks — The Cache"
  description="The best gear, tech, fashion, cars, and drinks — curated and reviewed by The Cache."
>
  <h1 style="font-size:1.75rem; font-weight:800; letter-spacing:-0.02em; margin-bottom:0.5rem; font-family:Georgia,serif;">The Picks</h1>
  <p style="color:var(--brand-muted); margin-bottom:3rem;">Gear, tech, style, cars, and drinks worth your attention.</p>

  <div style="display:flex; flex-direction:column; gap:1.5rem;">
    {articles.map(article => (
      <a href={`/articles/${article.slug}`} style="display:block; background:white; border:1px solid var(--brand-border); border-radius:10px; padding:1.5rem; text-decoration:none; color:inherit; transition:box-shadow 0.15s;">
        <div style={`font-size:0.75rem; font-weight:700; text-transform:uppercase; letter-spacing:0.08em; color:${categoryColors[article.data.category] ?? 'var(--brand-accent)'}; margin-bottom:0.4rem;`}>{article.data.category}</div>
        <h2 style="font-size:1.05rem; font-weight:700; margin-bottom:0.4rem; font-family:Georgia,serif;">{article.data.title}</h2>
        <p style="font-size:0.9rem; color:var(--brand-muted); margin:0;">{article.data.description}</p>
      </a>
    ))}
  </div>
</BaseLayout>
