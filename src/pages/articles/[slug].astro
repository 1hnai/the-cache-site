---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => data.status === 'live');
  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();
const { title, description, category, publishedDate, image, price, buyUrl } = article.data;

const formattedDate = new Date(publishedDate).toLocaleDateString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric'
});
---

<BaseLayout title={title} description={description} article={true} publishedDate={publishedDate}>
  <article class="article-wrap">
    <div class="article-header">
      <div class="article-meta">
        <a href="/articles" class="meta-back">Picks</a>
        <span class="meta-sep">/</span>
        <span class="meta-cat">{category}</span>
      </div>
      <h1 class="article-title">{title}</h1>
      <p class="article-date">{formattedDate}</p>
    </div>

    {price && buyUrl && (
      <div class="buy-strip">
        <span class="buy-price">{price}</span>
        <a href={buyUrl} class="buy-btn" target="_blank" rel="noopener noreferrer">Buy Now</a>
      </div>
    )}

    {image && (
      <div class="hero-image">
        <img src={image} alt={title} />
      </div>
    )}

    <div class="article-body">
      <Content />
    </div>
  </article>

  <div class="subscribe-bar">
    <h2>Get The Cache weekly</h2>
    <p>The best stuff you didn't know you needed — every week in your inbox.</p>
    <div class="subscribe-form">
      <input type="email" placeholder="your@email.com" aria-label="Email address" />
      <button class="btn">Subscribe free</button>
    </div>
  </div>
</BaseLayout>

<style>
  .article-wrap {
    max-width: var(--reading-width);
    margin: 0 auto;
  }

  /* ── Header ───────────────────────────────── */
  .article-header {
    padding: 2rem 0 2rem;
    border-bottom: 1px solid var(--brand-border);
    margin-bottom: 2rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .meta-back {
    color: var(--brand-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 500;
    font-size: 0.7rem;
  }

  .meta-back:hover { color: var(--brand-text); }

  .meta-sep {
    color: var(--brand-border-strong);
  }

  .meta-cat {
    color: var(--brand-accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
    font-size: 0.7rem;
  }

  .article-title {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    color: var(--brand-text);
    margin-bottom: 0.75rem;
  }

  .article-date {
    font-size: 0.8125rem;
    color: var(--brand-muted);
  }

  /* ── Buy strip ────────────────────────────── */
  .buy-strip {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    padding: 1rem 1.25rem;
    background: var(--brand-surface);
    border-radius: 6px;
    border: 1px solid var(--brand-border);
  }

  .buy-price {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--brand-text);
    flex: 1;
  }

  .buy-btn {
    padding: 0.5rem 1.1rem;
    background: var(--brand-accent);
    color: white;
    border-radius: 5px;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s;
    white-space: nowrap;
  }

  .buy-btn:hover {
    background: var(--brand-accent-hover);
    color: white;
  }

  /* ── Hero image ───────────────────────────── */
  .hero-image {
    margin-bottom: 2.5rem;
    border-radius: 6px;
    overflow: hidden;
    background: var(--brand-surface);
  }

  .hero-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Article body ─────────────────────────── */
  .article-body :global(p) {
    margin-bottom: 1.25rem;
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--brand-text);
  }

  .article-body :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 700;
    margin: 2.5rem 0 0.75rem;
    letter-spacing: -0.015em;
    color: var(--brand-text);
  }

  .article-body :global(h3) {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 2rem 0 0.5rem;
    color: var(--brand-text);
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 0.5rem 0 1.25rem 1.5rem;
  }

  .article-body :global(li) {
    margin-bottom: 0.4rem;
    font-size: 1.0625rem;
    line-height: 1.7;
  }

  .article-body :global(strong) { font-weight: 700; }

  .article-body :global(hr) {
    border: none;
    border-top: 1px solid var(--brand-border);
    margin: 2.5rem 0;
  }

  .article-body :global(a) {
    color: var(--brand-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .article-body :global(a:hover) {
    color: var(--brand-accent-hover);
  }

  .article-body :global(blockquote) {
    border-left: 3px solid var(--brand-accent);
    padding-left: 1.25rem;
    color: var(--brand-muted);
    margin: 1.5rem 0;
    font-style: italic;
  }
</style>
