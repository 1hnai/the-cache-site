---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const articles = await getCollection('articles');
articles.sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime());
const latest = articles.slice(0, 6);
---

<BaseLayout
  title="The Cache"
  description="The best stuff you didn't know you needed."
>
  <section class="hero">
    <p class="kicker">Men's Gear &amp; Lifestyle</p>
    <h1>The best stuff you didn't<br>know you needed.</h1>
    <p class="sub">Curated picks across gear, tech, style, cars, and drinks. Nothing paid for. Nothing average.</p>
    <div class="subscribe-bar">
      <p>Get the weekly drop in your inbox.</p>
      <div class="subscribe-form">
        <input type="email" placeholder="your@email.com" aria-label="Email address" />
        <button class="btn">Subscribe free</button>
      </div>
    </div>
  </section>

  <hr class="divider" />

  {latest.length > 0 ? (
    <section class="latest">
      <h2 class="section-label">Latest Picks</h2>
      <div class="picks-grid">
        {latest.map(article => (
          <a href={`/articles/${article.slug}`} class="pick-card">
            {article.data.image && (
              <div class="pick-image">
                <img src={article.data.image} alt={article.data.title} loading="lazy" />
              </div>
            )}
            <div class="pick-body">
              <span class="pick-category">{article.data.category}</span>
              <h3 class="pick-title">{article.data.title}</h3>
              {article.data.price && <span class="pick-price">{article.data.price}</span>}
            </div>
          </a>
        ))}
      </div>
    </section>
  ) : (
    <section class="latest">
      <h2 class="section-label">Latest Picks</h2>
      <p class="empty">First drop coming soon.</p>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    padding: 5rem 0 3.5rem;
    text-align: center;
  }

  .kicker {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-accent);
    margin-bottom: 1.25rem;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    line-height: 1.12;
    letter-spacing: -0.03em;
    font-family: Georgia, serif;
    margin-bottom: 1.25rem;
  }

  .sub {
    font-size: 1.05rem;
    color: var(--brand-muted);
    max-width: 480px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  .subscribe-bar {
    background: var(--brand-text);
    color: white;
    border-radius: 12px;
    padding: 1.75rem 2rem;
    max-width: 460px;
    margin: 0 auto;
    text-align: center;
  }

  .subscribe-bar p {
    font-size: 0.9rem;
    color: #a8a29e;
    margin-bottom: 1rem;
  }

  .subscribe-form {
    display: flex;
    gap: 0.5rem;
  }

  .subscribe-form input {
    flex: 1;
    padding: 0.6rem 1rem;
    border-radius: 8px;
    border: 1px solid #44403c;
    background: #292524;
    color: white;
    font-size: 0.9rem;
  }

  .btn {
    padding: 0.6rem 1.25rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    border: none;
    background: var(--brand-accent);
    color: white;
    white-space: nowrap;
    transition: opacity 0.15s;
  }

  .btn:hover { opacity: 0.85; }

  .divider {
    border: none;
    border-top: 1px solid var(--brand-border);
    margin: 2rem 0;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand-muted);
    margin-bottom: 1.5rem;
  }

  .picks-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .pick-card {
    display: block;
    background: white;
    border: 1px solid var(--brand-border);
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.15s;
  }

  .pick-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    text-decoration: none;
  }

  .pick-image {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--brand-surface);
  }

  .pick-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .pick-body {
    padding: 1.25rem;
  }

  .pick-category {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--brand-accent);
    display: block;
    margin-bottom: 0.4rem;
  }

  .pick-title {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.35;
    font-family: Georgia, serif;
    margin-bottom: 0.5rem;
  }

  .pick-price {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--brand-muted);
  }

  .empty {
    color: var(--brand-muted);
    font-style: italic;
  }

  @media (max-width: 600px) {
    .subscribe-form { flex-direction: column; }
    .picks-grid { grid-template-columns: 1fr; }
  }
</style>
