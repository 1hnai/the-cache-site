---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const articles = await getCollection('articles', ({ data }) => data.status === 'live');
articles.sort((a, b) => new Date(b.data.publishedDate).getTime() - new Date(a.data.publishedDate).getTime());
const featured = articles[0];
const rest = articles.slice(1, 7);
---

<BaseLayout
  title="The Cache"
  description="The best stuff you didn't know you needed."
>
  <section class="hero">
    <p class="kicker">Men's Gear &amp; Lifestyle</p>
    <h1>The best stuff you didn't know you needed.</h1>
    <p class="sub">Curated picks across gear, tech, style, cars, and drinks — nothing paid for, nothing average.</p>
  </section>

  {featured && (
    <section class="featured">
      <a href={`/articles/${featured.slug}`} class="featured-card">
        {featured.data.image && (
          <div class="featured-image">
            <img src={featured.data.image} alt={featured.data.title} loading="lazy" />
          </div>
        )}
        <div class="featured-body">
          <span class="card-category">{featured.data.category}</span>
          <h2 class="featured-title">{featured.data.title}</h2>
          <p class="featured-desc">{featured.data.description}</p>
          {featured.data.price && <span class="card-price">{featured.data.price}</span>}
        </div>
      </a>
    </section>
  )}

  {rest.length > 0 && (
    <section class="picks">
      <h2 class="section-label">Latest Picks</h2>
      <div class="picks-grid">
        {rest.map(article => (
          <a href={`/articles/${article.slug}`} class="pick-card">
            {article.data.image && (
              <div class="pick-image">
                <img src={article.data.image} alt={article.data.title} loading="lazy" />
              </div>
            )}
            <div class="pick-body">
              <span class="card-category">{article.data.category}</span>
              <h3 class="pick-title">{article.data.title}</h3>
              {article.data.price && <span class="card-price">{article.data.price}</span>}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  {articles.length === 0 && (
    <section class="picks">
      <h2 class="section-label">Latest Picks</h2>
      <p class="empty">First drop coming soon.</p>
    </section>
  )}

  <div class="subscribe-bar">
    <h2>Get the weekly drop</h2>
    <p>The best finds, straight to your inbox. No noise.</p>
    <div class="subscribe-form">
      <input type="email" placeholder="your@email.com" aria-label="Email address" />
      <button class="btn">Subscribe free</button>
    </div>
  </div>
</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────── */
  .hero {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--brand-border);
    margin-bottom: 3rem;
  }

  .kicker {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--brand-accent);
    margin-bottom: 1rem;
  }

  h1 {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--brand-text);
    margin-bottom: 1rem;
    max-width: 640px;
  }

  .sub {
    font-size: 1rem;
    color: var(--brand-muted);
    max-width: 520px;
    line-height: 1.65;
  }

  /* ── Featured card ───────────────────────── */
  .featured {
    margin-bottom: 3rem;
  }

  .featured-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--brand-border);
    border-radius: 6px;
    overflow: hidden;
    transition: box-shadow 0.15s;
  }

  .featured-card:hover {
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  }

  .featured-image {
    background: var(--brand-surface);
    aspect-ratio: 4/3;
    overflow: hidden;
  }

  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .featured-card:hover .featured-image img {
    transform: scale(1.02);
  }

  .featured-body {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--brand-bg);
  }

  .featured-title {
    font-family: var(--font-serif);
    font-size: clamp(1.4rem, 2.5vw, 1.85rem);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin: 0.5rem 0 0.75rem;
    color: var(--brand-text);
  }

  .featured-desc {
    font-size: 0.9375rem;
    color: var(--brand-muted);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  /* ── Shared card elements ─────────────────── */
  .card-category {
    font-size: 0.675rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-accent);
    display: block;
  }

  .card-price {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--brand-muted);
    display: block;
    margin-top: 0.25rem;
  }

  /* ── Picks grid ──────────────────────────── */
  .picks {
    margin-bottom: 0;
  }

  .section-label {
    font-size: 0.675rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--brand-muted);
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--brand-border);
  }

  .picks-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .pick-card {
    display: block;
    border: 1px solid var(--brand-border);
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.15s;
    background: var(--brand-bg);
  }

  .pick-card:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.07);
  }

  .pick-image {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: var(--brand-surface);
  }

  .pick-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .pick-card:hover .pick-image img {
    transform: scale(1.02);
  }

  .pick-body {
    padding: 1rem 1.125rem 1.125rem;
  }

  .pick-title {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.35;
    margin: 0.35rem 0 0.25rem;
    color: var(--brand-text);
  }

  .empty {
    color: var(--brand-muted);
    font-style: italic;
    padding: 2rem 0;
  }

  /* ── Responsive ──────────────────────────── */
  @media (max-width: 800px) {
    .featured-card { grid-template-columns: 1fr; }
    .featured-image { aspect-ratio: 16/9; }
    .featured-body { padding: 1.5rem; }
    .picks-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 500px) {
    .hero { padding: 2.5rem 0 2rem; }
    .picks-grid { grid-template-columns: 1fr; }
  }
</style>
