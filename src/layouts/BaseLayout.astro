---
interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  article?: boolean;
  publishedDate?: string;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage = '/og-default.png',
  article = false,
  publishedDate,
} = Astro.props;

const siteName = 'The Cache';
const siteUrl = 'https://thecache.com';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#1c1917" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content={article ? 'article' : 'website'} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    {publishedDate && <meta property="article:published_time" content={publishedDate} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />
    <meta name="twitter:site" content="@thecachecom" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": article ? "Article" : "WebSite",
      "name": siteName,
      "url": siteUrl,
      "description": "The best stuff you didn't know you needed.",
    })} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />

    <style>
      :root {
        --brand-bg: #fafaf9;
        --brand-surface: #f5f5f4;
        --brand-accent: #c2410c;
        --brand-accent-light: #ea580c;
        --brand-text: #1c1917;
        --brand-muted: #78716c;
        --brand-border: #e7e5e4;
        --max-width: 720px;
        --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
        --font-serif: Georgia, 'Times New Roman', serif;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { font-size: 16px; scroll-behavior: smooth; }

      body {
        font-family: var(--font-sans);
        background: var(--brand-bg);
        color: var(--brand-text);
        line-height: 1.7;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      a { color: var(--brand-accent-light); text-decoration: none; }
      a:hover { text-decoration: underline; }

      header { border-bottom: 1px solid var(--brand-border); padding: 1rem 1.5rem; background: white; }

      header nav {
        max-width: var(--max-width);
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 2rem;
      }

      .logo { font-weight: 800; font-size: 1.15rem; color: var(--brand-text); letter-spacing: -0.03em; font-family: var(--font-serif); }
      .logo em { color: var(--brand-accent); font-style: italic; }

      nav ul { list-style: none; display: flex; gap: 1.5rem; font-size: 0.9rem; }
      nav ul a { color: var(--brand-muted); }
      nav ul a:hover { color: var(--brand-text); text-decoration: none; }

      main {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 3rem 1.5rem;
        flex: 1;
        width: 100%;
      }

      footer { border-top: 1px solid var(--brand-border); padding: 2rem 1.5rem; text-align: center; font-size: 0.85rem; color: var(--brand-muted); background: white; }
      footer nav { display: flex; justify-content: center; gap: 1.5rem; margin-bottom: 1rem; }
      footer a { color: var(--brand-muted); }
      footer a:hover { color: var(--brand-text); text-decoration: none; }

      .subscribe-bar {
        background: var(--brand-text);
        color: white;
        border-radius: 12px;
        padding: 2rem;
        text-align: center;
        margin: 3rem 0;
      }

      .subscribe-bar h2 { font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem; }
      .subscribe-bar p { color: #a8a29e; font-size: 0.95rem; margin-bottom: 1.25rem; }

      .subscribe-form { display: flex; gap: 0.5rem; max-width: 400px; margin: 0 auto; }

      .subscribe-form input {
        flex: 1;
        padding: 0.6rem 1rem;
        border-radius: 8px;
        border: 1px solid #44403c;
        background: #292524;
        color: white;
        font-size: 0.95rem;
      }

      .btn {
        padding: 0.6rem 1.25rem;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        border: none;
        background: var(--brand-accent);
        color: white;
        transition: opacity 0.15s;
        white-space: nowrap;
      }

      .btn:hover { opacity: 0.85; }

      @media (max-width: 600px) { .subscribe-form { flex-direction: column; } }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="logo">The <em>Cache</em></a>
        <ul>
          <li><a href="/articles">Picks</a></li>
          <li><a href="/about">About</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <nav>
        <a href="/articles">Picks</a>
        <a href="/about">About</a>
        <a href="/rss.xml">RSS</a>
      </nav>
      <p>© {new Date().getFullYear()} The Cache. The best stuff you didn't know you needed.</p>
    </footer>
  </body>
</html>
